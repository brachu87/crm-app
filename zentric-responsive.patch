diff --git a/frontend/src/index.css b/frontend/src/index.css
index 3a4bce7..93f0728 100644
--- a/frontend/src/index.css
+++ b/frontend/src/index.css
@@ -2061,3 +2061,52 @@ h2 { font-weight: 600; }
   .toast-container { bottom: 16px; right: 16px; left: 16px; }
   .toast { max-width: 100%; }
 }
+
+/* ── Tablas como tarjetas apiladas en móvil ──────────── */
+@media (max-width: 600px) {
+  table.cards-mobile { min-width: 0 !important; width: 100%; }
+  table.cards-mobile thead { display: none; }
+  table.cards-mobile tbody { display: block; }
+  table.cards-mobile tr {
+    display: block;
+    border: 1px solid var(--border);
+    border-radius: 12px;
+    padding: 6px 14px;
+    margin-bottom: 10px;
+    background: var(--surface);
+  }
+  table.cards-mobile td {
+    display: flex !important;
+    justify-content: space-between;
+    align-items: center;
+    gap: 12px;
+    text-align: right;
+    padding: 8px 0 !important;
+    border: none !important;
+    border-bottom: 1px solid var(--border) !important;
+    min-width: 0;
+    width: auto;
+    white-space: normal;
+  }
+  table.cards-mobile tr td:last-child { border-bottom: none !important; }
+  table.cards-mobile td::before {
+    content: attr(data-label);
+    font-weight: 600;
+    color: var(--ink-soft);
+    text-align: left;
+    flex-shrink: 0;
+    white-space: nowrap;
+  }
+  table.cards-mobile td.actions-cell {
+    justify-content: stretch;
+    flex-wrap: wrap;
+    gap: 8px;
+    padding-top: 10px !important;
+  }
+  table.cards-mobile td.actions-cell::before { display: none; }
+  table.cards-mobile td.actions-cell > * {
+    flex: 1 1 auto;
+    justify-content: center;
+    text-align: center;
+  }
+}
