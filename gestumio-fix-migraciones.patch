diff --git a/backend/prisma/migrations/20260619500000_google_auth/migration.sql b/backend/prisma/migrations/20260619500000_google_auth/migration.sql
index e8a2fe5..3435352 100644
--- a/backend/prisma/migrations/20260619500000_google_auth/migration.sql
+++ b/backend/prisma/migrations/20260619500000_google_auth/migration.sql
@@ -1,2 +1,5 @@
--- Allow null password for Google OAuth users
-ALTER TABLE "User" ALTER COLUMN "password" DROP NOT NULL;
+-- Google OAuth: el password puede quedar vacío.
+-- En SQLite NO se puede `ALTER COLUMN ... DROP NOT NULL` (eso es sintaxis de PostgreSQL),
+-- y la app crea los usuarios de Google con password = '' (string vacío), así que no se
+-- requiere que la columna sea nullable. Migración no-op (válida en SQLite).
+PRAGMA foreign_keys=ON;
