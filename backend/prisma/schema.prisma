generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  category  String
  phone     String?
  cuit      String?
  address   String?
  email     String?
  website   String?
  instagram String?
  createdAt DateTime @default(now())

  subscriptionStatus   String   @default("trial")
  subscriptionExpires  DateTime?
  bonificado           Boolean  @default(false)

  approved   Boolean   @default(true)
  approvedAt DateTime?
  extraUsers Int       @default(0)

  waPhoneId     String?  // phone_number_id de Meta Cloud API (por negocio)
  waPhoneNumber String?  // numero visible para mostrar en la UI
  waWabaId      String?  // WhatsApp Business Account ID del negocio
  waToken       String?  // token de acceso del negocio (Embedded Signup)

  waTemplateExpiring    String?
  waTemplateOverdue     String?
  waTemplateAppointment String?
  waAutoReminders       Boolean  @default(false)
  waReminderHour        Int      @default(9)
  enabledModules        String?

  googleCalendarToken  String?
  googleCalendarId     String?
  gcalSyncTurnos       Boolean  @default(false)
  gcalSyncAgenda       Boolean  @default(false)
  gcalSyncClases       Boolean  @default(false)

  // Facturacion electronica (AFIP/ARCA - web services directos)
  fiscalCuit        String?
  fiscalRazonSocial String?
  fiscalCondicion   String?   // MONOTRIBUTO | RI | EXENTO
  fiscalPuntoVenta  String?   // ej "0001"
  fiscalDomicilio   String?
  afipEnv           String?   @default("homologacion") // homologacion | produccion
  afipKeyPem        String?   // clave privada generada por Gestumio
  afipCsrPem        String?   // CSR para subir a AFIP
  afipCertPem       String?   // certificado .crt devuelto por AFIP
  afipToken         String?   // cache del TA (WSAA)
  afipSign          String?
  afipTokenExp      DateTime?

  users      User[]
  clients    Client[]
  activities Activity[]
  employees  Employee[]
  expenses   Expense[]
  suppliers  Supplier[]
  notes            Note[]
  dailyCash        DailyCash[]
  manualIncomes    ManualIncome[]
  accountMovements AccountMovement[]
  branches         Branch[]
  classSchedules   ClassSchedule[]
  attendances      Attendance[]
  payrollRecords   PayrollRecord[]
  services         Service[]
  appointments     Appointment[]
  classReservations ClassReservation[]
  serviceSchedules ServiceSchedule[]
  invoices         Invoice[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String?
  name       String
  role        String   @default("owner")
  permissions String?
  lastAccessAt DateTime?
  onboardingSeen String?
  businessId  String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
}

model Client {
  id               String       @id @default(cuid())
  name             String
  phone            String?
  email            String?
  notes            String?
  birthday         DateTime?
  emergencyContact String?
  emergencyPhone   String?
  medicalNotes     String?
  active           Boolean      @default(true)
  dni              String?
  cuit             String?
  responsableName  String?
  responsablePhone String?
  globalDiscount   Float        @default(0)
  memberNumber     String?      @unique   // número de socio (usuario del portal), único global
  classReservations ClassReservation[]
  portalPassword   String?                // hash de la contraseña del portal (si no, usa el DNI)
  businessId       String
  business         Business     @relation(fields: [businessId], references: [id])
  enrollments      Enrollment[]
  clientNotes      ClientNote[]
  accountMovements AccountMovement[]
  appointments     Appointment[]
  manualIncomes    ManualIncome[]
  createdAt        DateTime     @default(now())

  @@index([businessId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Activity {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Float
  capacity    Int?
  schedule    String?
  reservationMode String   @default("daily") // daily | weekly | monthly
  active      Boolean      @default(true)
  billingDueDay Int?
  businessId  String
  business    Business     @relation(fields: [businessId], references: [id])
  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id])
  enrollments Enrollment[]
  activityEmployees ActivityEmployee[]
  classSchedules    ClassSchedule[]
  createdAt   DateTime     @default(now())

  @@index([businessId])
  @@index([branchId])
}

model Enrollment {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  activityId    String
  activity      Activity  @relation(fields: [activityId], references: [id])
  amountDue     Float     // monto base mensual: plantilla para generar las cuotas
  discount      Float     @default(0) // descuento base mensual
  startDate     DateTime  @default(now())
  active          Boolean   @default(true)
  bonificada      Boolean   @default(false)
  bonificadaHasta DateTime?

  cuotas Cuota[]

  @@unique([clientId, activityId])
  @@index([activityId])
  @@index([clientId])
}

// Cargo mensual de una inscripción. Una fila por período (mes).
model Cuota {
  id            String     @id @default(cuid())
  enrollmentId  String
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  period        String     // formato "YYYY-MM"
  amountDue     Float
  discount      Float      @default(0)
  paymentStatus String     @default("pending") // pending | paid | overdue
  dueDate       DateTime?
  createdAt     DateTime   @default(now())

  payments Payment[]

  @@unique([enrollmentId, period])
  @@index([enrollmentId])
}

model Payment {
  id        String   @id @default(cuid())
  cuotaId   String
  cuota     Cuota    @relation(fields: [cuotaId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime @default(now())
  method    String?

  @@index([cuotaId])
  @@index([date])
}

model Supplier {
  id         String    @id @default(cuid())
  name       String
  contact    String?
  phone      String?
  email      String?
  cuit       String?
  dni        String?
  category   String?
  notes      String?
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  expenses   Expense[]
  createdAt  DateTime  @default(now())

  @@index([businessId])
}

model Note {
  id         String    @id @default(cuid())
  title      String
  content    String?
  dueDate    DateTime?
  completed  Boolean   @default(false)
  priority   String    @default("normal")
  startAt    DateTime?
  endAt      DateTime?
  allDay     Boolean   @default(true)
  color      String    @default("blue")
  gcalEventId String?
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([businessId])
}

model DailyCash {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  openingBalance Float    @default(0)
  closingBalance Float?
  notes          String?
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  createdAt      DateTime @default(now())

  @@index([businessId])
  @@index([date])
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String
  phone     String?
  email     String?
  salary      Float?
  payType     String  @default("hourly")
  payFrequency String @default("monthly")
  startDate   DateTime @default(now())
  active    Boolean  @default(true)
  notes     String?
  businessId String
  business  Business @relation(fields: [businessId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  activityEmployees ActivityEmployee[]
  classSchedules    ClassSchedule[]
  attendances       Attendance[]
  payrollRecords    PayrollRecord[]
  services          Service[]
  appointments      Appointment[]

  @@index([businessId])
  @@index([branchId])
}

model Expense {
  id            String    @id @default(cuid())
  amount        Float
  date          DateTime  @default(now())
  category      String
  description   String?
  paymentMethod String?
  // Datos fiscales del comprobante (para Libro IVA Compras / ARCA)
  comprobanteTipo   String?
  puntoVenta        String?
  comprobanteNumero String?
  proveedorCuit     String?
  proveedorCondIva  String?
  netoGravado       Float?
  noGravado         Float?
  ivaAlicuota       Float?
  ivaMonto          Float?
  percepIva         Float?
  percepIIBB        Float?
  otrosTrib         Float?
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  createdAt     DateTime  @default(now())

  @@index([businessId])
  @@index([supplierId])
}

model AccountMovement {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String   // 'cargo' | 'abono'
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])

  @@index([clientId])
  @@index([businessId])
}

model Branch {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  address    String?
  phone      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  employees      Employee[]
  activities     Activity[]
  classSchedules ClassSchedule[]
  appointments   Appointment[]

  @@index([businessId])
}

model ActivityEmployee {
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([activityId, employeeId])
}

model ClassSchedule {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id])
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id])
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  dayOfWeek   Int
  startTime   String
  endTime     String
  maxCapacity Int?
  active      Boolean   @default(true)
  gcalEventId String?
  createdAt   DateTime  @default(now())

  @@index([businessId])
  @@index([branchId])
  @@index([activityId])
  attendances Attendance[]
  classReservations ClassReservation[]
}

model Attendance {
  id              String         @id @default(cuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id])
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime
  status          String         @default("present")
  hoursWorked     Float          @default(0)
  notes           String?
  classScheduleId String?
  classSchedule   ClassSchedule? @relation(fields: [classScheduleId], references: [id])
  createdAt       DateTime       @default(now())

  @@index([businessId])
  @@index([employeeId])
}

model PayrollRecord {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  totalHours  Float    @default(0)
  payRate     Float
  payType     String
  totalAmount Float
  status      String   @default("pending")
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([employeeId])
}

model Service {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  name        String
  description String?
  duration    Int       @default(60)
  price       Float     @default(0)
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  active      Boolean   @default(true)
  onlineBooking Boolean @default(false)  // el socio puede reservar este servicio online
  createdAt   DateTime  @default(now())
  appointments Appointment[]
  schedules   ServiceSchedule[]

  @@index([businessId])
}

model Appointment {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  serviceId     String?
  service       Service?  @relation(fields: [serviceId], references: [id])
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id])
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  description   String?
  date          String
  startTime     String    @default("")
  endTime       String    @default("")
  price         Float     @default(0)
  status        String    @default("scheduled")
  confirmCode   String?   // código corto para confirmar/rechazar por WhatsApp
  paymentStatus String    @default("pending")
  paidAt        DateTime?
  notes         String?
  isQuickWork   Boolean   @default(false)
  gcalEventId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
  @@index([serviceId])
  @@index([clientId])
  @@index([employeeId])
}

model ManualIncome {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  amount      Float
  description String
  category    String   @default("Otro")
  date        String
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([clientId])
}

model ClassReservation {
  id              String        @id @default(cuid())
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id])
  classScheduleId String
  classSchedule   ClassSchedule @relation(fields: [classScheduleId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  date            String        // "YYYY-MM-DD"
  status          String        @default("reserved") // reserved | cancelled
  periodType      String        @default("daily") // daily | weekly | monthly
  periodKey       String?       // weekly: lunes YYYY-MM-DD · monthly: YYYY-MM
  createdAt       DateTime      @default(now())

  @@index([businessId])
  @@index([classScheduleId])
  @@index([clientId])
}


model ServiceSchedule {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 0 = domingo ... 6 = sábado
  startTime   String   // "HH:MM"
  endTime     String   // "HH:MM"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([serviceId])
}

model Invoice {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  clientId       String?
  cuotaId        String?
  tipo           String   // "FACTURA A" | "FACTURA B" | "FACTURA C"
  puntoVenta     String?
  numero         String?
  cae            String?
  vencimientoCae String?
  clienteNombre  String?
  clienteDoc     String?
  total          Float    @default(0)
  moneda         String   @default("PES")
  neto           Float?
  iva            Float?
  docTipoCode    Int?
  condReceptor   Int?
  status         String   @default("issued") // issued | error
  errorMsg       String?
  qrUrl          String?
  detalleJson    String?
  createdAt      DateTime @default(now())

  @@index([businessId])
  @@index([clientId])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  userName   String?
  action     String
  entity     String?
  entityId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([createdAt])
}
