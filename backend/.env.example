# Copiar este archivo como .env y completar los valores

# Base de datos - En Railway con volumen montado en /data:
DATABASE_URL="file:/data/prod.db"

# Secreto para JWT - Cambiar por una cadena larga y aleatoria:
JWT_SECRET="reemplazar-con-secreto-largo-aleatorio-ej-abc123xyz456"

# Puerto (Railway lo setea automáticamente, no hace falta cambiarlo)
PORT=4000
